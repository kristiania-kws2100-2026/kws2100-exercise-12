{
  "name": "kws2100-exercise-12",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "tsc --noEmit && prettier --check .",
    "dev": "concurrently npm:dev:client npm:dev:server",
    "dev:client": "vite",
    "dev:server": "cd server && npm run dev",
    "prepare": "husky",
    "db:load:docker": "npm run db:grunnskoler:download && npm run db:grunnskoler:load:docker",
    "db:grunnskoler:download": "download --extract --out tmp/ https://nedlasting.geonorge.no/geonorge/Befolkning/Grunnskoler/PostGIS/Befolkning_0000_Norge_25833_Grunnskoler_PostGIS.zip",
    "db:grunnskoler:load:docker": "npm run db:psql:docker < tmp/Befolkning_0000_Norge_25833_Grunnskoler_PostGIS.sql",
    "db:psql:docker": "docker exec -i /postgis /usr/bin/psql --user postgres",
    "db:load:server": "npm run db:init:server && npm run db:grunnskoler:download && npm run db:grunnskoler:load:server",
    "db:init:server": "echo create extension if not exists postgis | psql $DATABASE_URL",
    "db:grunnskoler:load:server": "psql $DATABASE_URL < tmp/Befolkning_0000_Norge_25833_Grunnskoler_PostGIS.sql"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kristiania-kws2100-2026/kws2100-exercise-12.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kristiania-kws2100-2026/kws2100-exercise-12/issues"
  },
  "homepage": "https://github.com/kristiania-kws2100-2026/kws2100-exercise-12#readme",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "download-cli": "^1.1.1",
    "ol": "^10.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "type": "module"
}
